# Credenciales publicas de Supabase (la publishable key es segura de exponer en el cliente).
# Copia este archivo a .env y rellena con los valores de tu proyecto:
#   Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
